            },
            "url": {
              "raw": "{{baseUrl}}/payment/process",
              "host": ["{{baseUrl}}"],
              "path": ["payment", "process"]
            },
            "description": "Process a successful dummy payment. Card numbers not starting with 0000 or 9999 succeed."
          },
          "response": [],
          "event": [
